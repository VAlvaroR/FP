<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE clinica [
    <!ELEMENT clinica (fisioterapeutas, pacientes,tratamientos)>
    <!ATTLIST clinica nombre CDATA #REQUIRED>
    <!ATTLIST clinica ciudad CDATA #IMPLIED>

    <!ELEMENT fisioterapeutas (fisioterapeuta)+>

    <!ELEMENT fisioterapeuta (nombre, telefono, email)>
    <!ATTLIST fisioterapeuta id ID #REQUIRED>
    <!ATTLIST fisioterapeuta especialidad CDATA #REQUIRED>

    <!ELEMENT nombre (#PCDATA)>
    <!ELEMENT telefono (#PCDATA)>
    <!ELEMENT email (#PCDATA)>

    <!ELEMENT pacientes (paciente)+>

    <!ELEMENT paciente (nombre, edad, observaciones?)>
    <!ATTLIST paciente id ID #REQUIRED>
    <!ATTLIST paciente estado (activo|alta) "activo">

    <!ELEMENT edad (#PCDATA)>
    <!ELEMENT observaciones (#PCDATA)>

    <!ELEMENT tratamientos (tratamiento)+>

    <!ELEMENT tratamiento (nombre, duracion, precio, materiales?, sesiones)>
    <!ATTLIST tratamiento codigo ID #REQUIRED>
    <!ATTLIST tratamiento tipo CDATA #REQUIRED>
    <!ATTLIST tratamiento pacienteRef IDREF #REQUIRED>
    <!ATTLIST tratamiento fisioRef IDREF #REQUIRED>

    <!ELEMENT duracion (#PCDATA)>
    <!ELEMENT precio (#PCDATA)>
    <!ELEMENT materiales (material)+>
    <!ELEMENT sesiones (sesion)+>

    <!ELEMENT material (#PCDATA)>

    <!ELEMENT sesion EMPTY>
    <!ATTLIST sesion fecha CDATA #REQUIRED>
]>

