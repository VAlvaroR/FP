<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE listacompras [
    <!ELEMENT listacompras (venta)+>
    <!ELEMENT venta (ventacredito | ventainmediata)>
    <!ELEMENT ventacredito (#PCDATA)>
    <!ATTLIST ventacredito fechafinpago CDATA #IMPLIED>
    <!ATTLIST ventacredito cantidad CDATA #REQUIRED>
    <!ELEMENT ventainmediata (cantidad,divisa)>
    <!ELEMENT cantidad (#PCDATA)>
    <!ELEMENT divisa (#PCDATA)>
]>

<listacompras>
    <venta>
        <ventacredito fechafinpago="123131" cantidad="2">
        </ventacredito>
    </venta>

    <venta>
        <ventainmediata>
            <cantidad>2</cantidad>
            <divisa>EUR</divisa>
        </ventainmediata>
    </venta>
</listacompras>